# ============================================
# YCYW 2026 Global IT Meeting - Backend .env
# Copy this file to `.env` and adjust values.
# ============================================

# Application
NODE_ENV=development
PORT=3000
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Public origin of the frontend (for CORS). Comma separated allowed.
CORS_ORIGIN=http://localhost:5173

# ----- Database -----
# Development default: SQLite file DB
DATABASE_URL="file:./dev.db"
# Production example (PostgreSQL):
# DATABASE_URL="postgresql://meeting:meetingpass@localhost:5432/global_it"

# ----- Admin emails (comma separated) -----
# Users whose email matches will get isAdmin=true on creation/login.
ADMIN_EMAILS="admin@ycyw.cn,ying.hou@ycyw.cn"

# ----- Storage -----
# false  = local disk (./uploads)
# true   = Aliyun OSS (configure below)
USE_OSS=false
OSS_REGION=cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_SECRET=
OSS_BUCKET=your-bucket
OSS_ENDPOINT=
OSS_PUBLIC_BASE_URL=

# ----- OIDC (reserved, NOT enabled by default) -----
# When OIDC_ENABLED=true, users are redirected to the external OIDC provider.
# When OIDC_ENABLED=false, the system uses the mock email-only login (AuthModal).
# Uses openid-client v6 (ESM-only, functional API).
OIDC_ENABLED=false
OIDC_AUTHORITY=https://auth-test.ywies.com/
OIDC_CLIENT_ID=IT-Meeting
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/api/auth/oidc-callback
OIDC_SCOPES=openid email profile
OIDC_FRONTEND_CALLBACK=/auth/callback

# ----- Upload limits (bytes) -----
MAX_IMAGE_SIZE=10485760     # 10 MB
MAX_VIDEO_SIZE=52428800     # 50 MB
